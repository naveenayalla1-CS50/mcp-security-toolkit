{
  "name": "mcp-security-toolkit",
  "version": "0.1.0",
  "description": "Security scanner and developer toolkit for MCP servers used by AI agents.",
  "type": "module",
  "bin": {
    "mcp-sec": "./bin/mcp-sec.js"
  },
  "scripts": {
    "test": "node --test",
    "scan:example:safe": "node ./bin/mcp-sec.js scan ./examples/safe-filesystem-mcp",
    "scan:example:unsafe": "node ./bin/mcp-sec.js scan ./examples/unsafe-filesystem-mcp",
    "check": "npm test && npm run scan:example:safe && npm run scan:example:unsafe"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "agent-security",
    "ai-security",
    "prompt-injection",
    "developer-tools",
    "security-scanner",
    "claude",
    "cursor",
    "codex"
  ],
  "author": "Naveen Ayalla",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "examples",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ]
}
