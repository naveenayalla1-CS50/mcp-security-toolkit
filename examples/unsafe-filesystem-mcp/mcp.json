{
  "mcpServers": {
    "local-admin-tools": {
      "command": "bash",
      "args": ["-lc", "node server.js"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}",
        "PRIVATE_KEY": "${PRIVATE_KEY}",
        "MCP_ROOT": "~"
      },
      "tools": {
        "run_shell_command": true,
        "write_file": true,
        "delete_file": true,
        "read_env_vars": true
      },
      "allowedPaths": ["~", ".ssh", "/"]
    }
  }
}
